{
  "info": {
    "name": "Event Ticketing System",
    "description": "Full booking flow. Run seed.py first, then set show_id variable.\n\nAfter Login, tokens auto-save.\nAfter Lock Seat, idempotency_key auto-saves.\nAfter Book, booking_id auto-saves.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:8000" },
    { "key": "show_id", "value": "3867bf92-82c7-40ba-81f1-ea6bb5db0193" },
    { "key": "access_token", "value": "" },
    { "key": "refresh_token", "value": "" },
    { "key": "queue_token", "value": "" },
    { "key": "idempotency_key", "value": "" },
    { "key": "booking_id", "value": "" }
  ],
  "item": [
    {
      "name": "1 - Auth",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/v1/auth/signup", "host": ["{{base_url}}"], "path": ["v1", "auth", "signup"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"you@example.com\",\n  \"password\": \"SuperSecret123!\"\n}" }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var b = pm.response.json();",
                  "if (b.access_token) {",
                  "  pm.collectionVariables.set('access_token', b.access_token);",
                  "  pm.collectionVariables.set('refresh_token', b.refresh_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/v1/auth/login", "host": ["{{base_url}}"], "path": ["v1", "auth", "login"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"you@example.com\",\n  \"password\": \"SuperSecret123!\"\n}" }
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var b = pm.response.json();",
                  "if (b.access_token) {",
                  "  pm.collectionVariables.set('access_token', b.access_token);",
                  "  pm.collectionVariables.set('refresh_token', b.refresh_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/v1/auth/refresh", "host": ["{{base_url}}"], "path": ["v1", "auth", "refresh"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}" }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/v1/auth/logout", "host": ["{{base_url}}"], "path": ["v1", "auth", "logout"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}" }
          }
        }
      ]
    },
    {
      "name": "2 - Catalog (Public, No Auth)",
      "item": [
        {
          "name": "List Venues",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/v1/venues", "host": ["{{base_url}}"], "path": ["v1", "venues"] }
          }
        },
        {
          "name": "List Events",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/v1/events", "host": ["{{base_url}}"], "path": ["v1", "events"] }
          }
        },
        {
          "name": "Get Showtime",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/v1/showtimes/{{show_id}}", "host": ["{{base_url}}"], "path": ["v1", "showtimes", "{{show_id}}"] }
          }
        },
        {
          "name": "Get Seat Map",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/v1/showtimes/{{show_id}}/seats", "host": ["{{base_url}}"], "path": ["v1", "showtimes", "{{show_id}}", "seats"] }
          }
        }
      ]
    },
    {
      "name": "3 - Queue",
      "item": [
        {
          "name": "Join Queue",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var b = pm.response.json();",
                  "if (b.queue_token) pm.collectionVariables.set('queue_token', b.queue_token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/v1/queue/join", "host": ["{{base_url}}"], "path": ["v1", "queue", "join"] },
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"show_id\": \"{{show_id}}\"\n}" }
          }
        },
        {
          "name": "Check Queue Status",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var b = pm.response.json();",
                  "if (b.queue_token) pm.collectionVariables.set('queue_token', b.queue_token);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/v1/queue/status?show_id={{show_id}}", "host": ["{{base_url}}"], "path": ["v1", "queue", "status"], "query": [{ "key": "show_id", "value": "{{show_id}}" }] },
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        },
        {
          "name": "Recover Queue",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/v1/queue/recover?show_id={{show_id}}", "host": ["{{base_url}}"], "path": ["v1", "queue", "recover"], "query": [{ "key": "show_id", "value": "{{show_id}}" }] },
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        }
      ]
    },
    {
      "name": "4 - Seat Lock",
      "item": [
        {
          "name": "Lock Seat A1",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var b = pm.response.json();",
                  "if (b.idempotency_key) pm.collectionVariables.set('idempotency_key', b.idempotency_key);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/v1/seats/lock", "host": ["{{base_url}}"], "path": ["v1", "seats", "lock"] },
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"show_id\": \"{{show_id}}\",\n  \"seat_id\": \"A1\"\n}" }
          }
        },
        {
          "name": "Lock Seat A2 (Second Seat)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/v1/seats/lock", "host": ["{{base_url}}"], "path": ["v1", "seats", "lock"] },
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"show_id\": \"{{show_id}}\",\n  \"seat_id\": \"A2\"\n}" }
          }
        },
        {
          "name": "Lock Same Seat (Should 409)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/v1/seats/lock", "host": ["{{base_url}}"], "path": ["v1", "seats", "lock"] },
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"show_id\": \"{{show_id}}\",\n  \"seat_id\": \"A1\"\n}" }
          }
        }
      ]
    },
    {
      "name": "5 - Book",
      "item": [
        {
          "name": "Book Seat A1",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var b = pm.response.json();",
                  "if (b.booking_id) pm.collectionVariables.set('booking_id', b.booking_id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/v1/book", "host": ["{{base_url}}"], "path": ["v1", "book"] },
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "X-Queue-Token", "value": "{{queue_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"show_id\": \"{{show_id}}\",\n  \"seat_id\": \"A1\",\n  \"idempotency_key\": \"{{idempotency_key}}\"\n}" }
          }
        }
      ]
    },
    {
      "name": "6 - Payment",
      "item": [
        {
          "name": "Create Payment Intent",
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/v1/payments/intent", "host": ["{{base_url}}"], "path": ["v1", "payments", "intent"] },
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"booking_id\": \"{{booking_id}}\"\n}" }
          }
        }
      ]
    },
    {
      "name": "7 - Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/health", "host": ["{{base_url}}"], "path": ["health"] }
          }
        },
        {
          "name": "Readiness Check",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/ready", "host": ["{{base_url}}"], "path": ["ready"] }
          }
        }
      ]
    }
  ]
}
