# ── Required ────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname?ssl=require
REDIS_URL=redis://localhost:6379/0
CORS_ORIGINS=http://localhost:5173
CLIENT_ORIGIN=http://localhost:5173

# ── JWT (auto-generated RSA keys in dev via Dockerfile) ─────────────
# JWT_PRIVATE_KEY_PATH=certs/private.pem
# JWT_PUBLIC_KEY_PATH=certs/public.pem

# ── Stripe (optional — leave empty to skip payments) ────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Google OAuth2 (optional) ────────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── Observability (optional) ────────────────────────────────────────
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=development
# OTEL_EXPORTER_OTLP_ENDPOINT=

# ── Rate limiting ──────────────────────────────────────────────────
# RATE_LIMIT_PUBLIC=60/minute
# RATE_LIMIT_AUTH=10/minute
# RATE_LIMIT_BOOKING=5/minute

# ── Logging ─────────────────────────────────────────────────────────
# LOG_LEVEL=INFO
# LOG_FORMAT=json
